{
    "name": "simpoly-cpu",
    "build": {
        "dockerfile": "../../Dockerfile",
        "context": "../.."
    },
    "postCreateCommand": "",
    "containerEnv": {
        "PYTHONPATH": "${containerWorkspaceFolder}/src/"
    },
    "mounts": [],
    "runArgs": [
        "--shm-size=2gb",
        "--network=host"
    ],
    "forwardPorts": [],
    "containerUser": "${localEnv:USER}",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": false,
            "installOhMyZsh": false,
            "upgradePackages": false,
            // If a user with this UID already exists in the image, comment the following lines and set "containerUser" to that user instead.
            "username": "${localEnv:USER}",
            "userUid": "${localEnv:UID}",
            "userGid": "${localEnv:UID}"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "charliermarsh.ruff",
                "ms-toolsai.jupyter"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/opt/miniforge3/envs/simpoly/bin/python",
                "[python]": {
                    "editor.formatOnSave": true,
                    "editor.defaultFormatter": "charliermarsh.ruff"
                },
                "python.testing.pytestArgs": [
                    "${containerWorkspaceFolder}/tests/"
                ],
                "python.testing.unittestEnabled": false,
                "python.testing.pytestEnabled": true
            }
        }
    }
}